# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_APP_ID=your-app-id
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# AI API Configuration
# Choose one: GEMINI, OPENAI, or CUSTOM
AI_SERVICE_TYPE=GEMINI
AI_API_KEY=your-ai-api-key

# Gemini API
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_ID=your-org-id

# App Configuration
APP_NAME=DookAI
APP_VERSION=1.0.0
APP_PACKAGE_NAME=com.example.dookai
ANDROID_PACKAGE_NAME=com.example.dookai
IOS_BUNDLE_ID=com.example.dookai

# Firebase Emulator Configuration (for local development)
USE_FIREBASE_EMULATOR=false
EMULATOR_HOST=localhost
FIRESTORE_EMULATOR_PORT=8080
AUTH_EMULATOR_PORT=9099
